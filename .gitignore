# Compiled binaries and runtime
*.exe
*.dll
64bit/
redist/

# User data and runtime files
config.json
config.json.bak*
data/
debug_log.txt
hotkey_debug.log
raw.wav
response.txt
clean_response.txt
payload.json
ffmpeg_stdout.txt

# Build and signing
signing/
installer/output/

# Lib runtime binaries
lib/64bit/
lib/*.dll

# E.2 transcription lab — personal dictation content stays local, NEVER commit.
# local-corpus holds probes derived from the user's real history; results echo
# model outputs of those probes.
tests/cleanup/local-corpus/
tests/cleanup/results/

# Private signing keys — NEVER commit (T2.5). The Ed25519 PRIVATE key that signs
# license JWTs + version.json lives only in the CF secret store + an offline
# backup. Only the PUBLIC key (raw-32 base64url) is baked into the app source.
*.pem
*.key
*-private.pem
*-ed25519-private.pem
.quicksay-keys/
**/.quicksay-keys/

# Local-only artifacts (2026-07-22 hygiene)
my-dev-license-token.txt
installer/
*.bak
.playwright-mcp/
